# NextAuth
NEXTAUTH_SECRET=your-secret-key-at-least-32-chars
NEXTAUTH_URL=http://localhost:3000

# Gmail SMTP (use an App Password, not your real password)
# Go to Google Account > Security > 2-Step Verification > App passwords
GMAIL_USER=your-email@gmail.com
GMAIL_PASS=your-16-char-app-password

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a $9/month recurring price in Stripe Dashboard and paste the Price ID here
STRIPE_PRICE_ID=price_...

# Database path (optional, defaults to ./data/bookeasy.db)
# DATABASE_URL=./data/bookeasy.db

# App URL (used for redirect links in emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000
